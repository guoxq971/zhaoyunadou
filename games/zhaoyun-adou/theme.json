    "motion": {
      "titleRevealSeconds": 0.5,
      "feedbackSeconds": 0.62,
      "batchStepSeconds": 0.08,
      "invalidReboundSeconds": 0.22,
      "targetPulseHz": 1.2
    },
    "dragonSkill": {
      "birthSeconds": 0.46,
      "startScale": 0.08,
      "arcLift": 32,
      "originGlowRadius": 24,
      "trailWidth": 4.5
    },
    "route": {
      "lineWidth": 2.4,
      "underlayWidth": 4.4,
      "dash": [7, 5],
      "primaryAlpha": 0.84,
      "secondaryAlpha": 0.7,
      "markerRadius": 11,
      "arrowSize": 7,
      "arrowAlpha": 0.95
