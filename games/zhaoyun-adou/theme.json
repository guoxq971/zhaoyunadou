    "hero.guanyu": { "paper": "#dfe8d0", "accent": "#4d7449", "ink": "#285432", "glow": "rgba(76,132,74,0.32)", "weaponRendererId": "weapon.guandao" },
    "hero.zhangfei": { "paper": "#eadced", "accent": "#815783", "ink": "#65316d", "glow": "rgba(143,82,151,0.32)", "weaponRendererId": "weapon.serpent-spear" },
    "hero.zhaoyun": { "paper": "#dbe8ed", "accent": "#547e95", "ink": "#2e647f", "glow": "rgba(76,142,176,0.34)", "weaponRendererId": "weapon.spear" },
