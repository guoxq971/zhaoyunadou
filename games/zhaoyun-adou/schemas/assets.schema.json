{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhaoyun-adou.local/schemas/assets.schema.json",
  "title": "Assets manifest",
  "type": "object",
  "required": ["schemaVersion", "version", "assets"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "$ref": "#/$defs/version" },
    "version": { "$ref": "#/$defs/version" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "asset": {
      "type": "object",
      "required": ["id", "path", "type", "format", "width", "height", "usage", "loadPriority", "required"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "type": "string", "minLength": 1 },
        "type": { "enum": ["image", "audio"] },
        "format": { "enum": ["png", "jpeg", "webp", "svg", "mp3", "ogg", "wav"] },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "usage": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "loadPriority": { "enum": ["critical", "high", "normal", "deferred"] },
        "required": { "type": "boolean" },
        "fallbackRendererId": { "$ref": "#/$defs/id" }
      }
    }
  }
}
