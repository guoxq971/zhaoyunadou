{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhaoyun-adou.local/schemas/theme.schema.json",
  "title": "Theme manifest",
  "type": "object",
  "required": ["schemaVersion", "version", "id", "themeCatalog", "fontFamily", "assetRefs", "assetBindings", "colors", "layout", "heroVisuals", "renderers", "toolAtlas", "feedback", "presentation"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "$ref": "#/$defs/version" },
    "version": { "$ref": "#/$defs/version" },
    "id": { "$ref": "#/$defs/id" },
    "themeCatalog": { "$ref": "#/$defs/themeCatalog" },
    "fontFamily": { "type": "string", "minLength": 1 },
    "assetRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "assetBindings": {
      "type": "object",
      "required": ["battleBackdrop", "titleMascot", "toolIconAtlas"],
      "additionalProperties": false,
      "properties": {
        "battleBackdrop": { "$ref": "#/$defs/id" },
        "titleMascot": { "$ref": "#/$defs/id" },
        "toolIconAtlas": { "$ref": "#/$defs/id" }
      }
    },
    "colors": {
      "type": "object",
      "required": [
        "paperRaised", "inkStrong", "inkStructure", "cinnabarPrimary", "cinnabarAction",
        "goldReward", "qingPlayable", "qingPlayableWash", "lockedCell", "openCell",
        "pathCell", "routeLine", "routeArrow", "boardSurface", "boardFrame"
      ],
      "minProperties": 1,
      "patternProperties": { "^[a-z][A-Za-z0-9]*$": { "type": "string", "minLength": 1 } },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": { "^[a-z][A-Za-z0-9]*$": { "$ref": "#/$defs/rect" } },
      "additionalProperties": false
    },
    "heroVisuals": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": { "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$": { "$ref": "#/$defs/heroVisual" } },
      "additionalProperties": false
    },
    "renderers": {
      "type": "object",
      "required": ["scenes", "troops", "enemies", "items", "effects"],
      "additionalProperties": false,
      "properties": {
        "scenes": { "$ref": "#/$defs/registry" },
        "troops": { "$ref": "#/$defs/registry" },
        "enemies": { "$ref": "#/$defs/registry" },
        "items": { "$ref": "#/$defs/registry" },
        "effects": { "$ref": "#/$defs/registry" }
      }
    },
    "toolAtlas": {
      "type": "object",
      "required": ["assetId", "columns", "rows", "sourceSize", "slots"],
      "additionalProperties": false,
      "properties": {
        "assetId": { "$ref": "#/$defs/id" },
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "sourceSize": { "type": "integer", "minimum": 1 },
        "slots": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": { "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$": { "type": "integer", "minimum": 0 } },
          "additionalProperties": false
        }
      }
    },
    "feedback": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": { "^[a-z][a-z0-9_]*$": { "$ref": "#/$defs/feedback" } },
      "additionalProperties": false
    },
    "presentation": {
      "$ref": "#/$defs/presentation"
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "themeCatalog": {
      "type": "object",
      "required": ["defaultThemeId", "storageKey", "options"],
      "additionalProperties": false,
      "properties": {
        "defaultThemeId": { "$ref": "#/$defs/id" },
        "storageKey": { "type": "string", "minLength": 1 },
        "options": {
          "type": "object",
          "minProperties": 2,
          "patternProperties": {
            "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$": { "$ref": "#/$defs/themeOption" }
          },
          "additionalProperties": false
        }
      }
    },
    "themeOption": {
      "type": "object",
      "required": ["labelCopyId", "boardRendererId", "pieceRendererId", "enemyRendererId"],
      "additionalProperties": false,
      "properties": {
        "labelCopyId": { "$ref": "#/$defs/id" },
        "boardRendererId": { "enum": ["board.ink-flat", "board.cloud-arena-2-5d"] },
        "pieceRendererId": { "enum": ["piece.paper-card", "piece.calligraphy-only"] },
        "enemyRendererId": { "enum": ["enemy.ink-glyph", "enemy.calligraphy-only"] },
        "colorOverrides": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": { "^[a-z][A-Za-z0-9]*$": { "type": "string", "minLength": 1 } },
          "additionalProperties": false
        },
        "boardStyle": { "$ref": "#/$defs/boardStyle" },
        "pieceStyle": { "$ref": "#/$defs/pieceStyle" }
      }
    },
    "boardStyle": {
      "type": "object",
      "required": ["tileInset", "tileDepth", "platformDepth", "cornerRadius", "highlightAlpha", "projection"],
      "additionalProperties": false,
      "properties": {
        "tileInset": { "type": "number", "minimum": 0, "maximum": 6 },
        "tileDepth": { "type": "number", "minimum": 0, "maximum": 12 },
        "platformDepth": { "type": "number", "minimum": 0, "maximum": 20 },
        "cornerRadius": { "type": "number", "minimum": 0, "maximum": 10 },
        "highlightAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
        "stoneGrainAlpha": { "type": "number", "minimum": 0, "maximum": 0.4 },
        "stoneVariationAlpha": { "type": "number", "minimum": 0, "maximum": 0.2 },
        "routeSurfaceAlpha": { "type": "number", "minimum": 0.5, "maximum": 1 },
        "wallBlockCount": { "type": "integer", "minimum": 4, "maximum": 16 },
        "projection": { "$ref": "#/$defs/boardProjection" }
      }
    },
    "boardProjection": {
      "type": "object",
      "required": ["mode", "topScale", "bottomScale", "verticalScale"],
      "additionalProperties": false,
      "properties": {
        "mode": { "const": "shallow-perspective" },
        "topScale": { "type": "number", "minimum": 0.75, "maximum": 1 },
        "bottomScale": { "type": "number", "minimum": 0.85, "maximum": 1.1 },
        "verticalScale": { "type": "number", "minimum": 0.75, "maximum": 1 }
      }
    },
    "pieceStyle": {
      "type": "object",
      "required": ["troopScale", "heroScale", "enemyScale", "shadowBlur", "shadowOffsetY", "echoOffset", "levelScale"],
      "additionalProperties": false,
      "properties": {
        "troopScale": { "type": "number", "minimum": 0.5, "maximum": 1.2 },
        "heroScale": { "type": "number", "minimum": 0.5, "maximum": 1.2 },
        "enemyScale": { "type": "number", "minimum": 0.5, "maximum": 1.4 },
        "shadowBlur": { "type": "number", "minimum": 0, "maximum": 16 },
        "shadowOffsetY": { "type": "number", "minimum": 0, "maximum": 10 },
        "echoOffset": { "type": "number", "minimum": 0, "maximum": 4 },
        "levelScale": { "type": "number", "minimum": 0.12, "maximum": 0.4 }
      }
    },
    "rect": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "minimum": 0 },
        "y": { "type": "number", "minimum": 0 },
        "w": { "type": "number", "exclusiveMinimum": 0 },
        "h": { "type": "number", "exclusiveMinimum": 0 },
        "gap": { "type": "number", "minimum": 0 }
      }
    },
    "heroVisual": {
      "type": "object",
      "required": ["paper", "accent", "ink", "glow", "weaponRendererId"],
      "additionalProperties": false,
      "properties": {
        "paper": { "type": "string", "minLength": 1 },
        "accent": { "type": "string", "minLength": 1 },
        "ink": { "type": "string", "minLength": 1 },
        "glow": { "type": "string", "minLength": 1 },
        "weaponRendererId": { "$ref": "#/$defs/id" }
      }
    },
    "registry": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": { "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$": { "$ref": "#/$defs/id" } },
      "additionalProperties": false
    },
    "feedback": {
      "type": "object",
      "required": ["effectId", "color"],
      "additionalProperties": false,
      "properties": {
        "effectId": { "enum": ["effect.ring", "effect.text"] },
        "color": { "type": "string", "minLength": 1 }
      }
    },
    "presentation": {
      "type": "object",
      "required": ["backdrop", "strokes", "shadows", "motion", "dragonSkill", "route", "title"],
      "additionalProperties": false,
      "properties": {
        "backdrop": {
          "type": "object",
          "required": ["artAlpha", "veilTop", "veilMid", "veilBottom"],
          "additionalProperties": false,
          "properties": {
            "artAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
            "veilTop": { "type": "string", "minLength": 1 },
            "veilMid": { "type": "string", "minLength": 1 },
            "veilBottom": { "type": "string", "minLength": 1 }
          }
        },
        "strokes": {
          "type": "object",
          "required": ["hairline", "default", "strong", "focus"],
          "additionalProperties": false,
          "properties": {
            "hairline": { "type": "number", "exclusiveMinimum": 0, "maximum": 8 },
            "default": { "type": "number", "exclusiveMinimum": 0, "maximum": 8 },
            "strong": { "type": "number", "exclusiveMinimum": 0, "maximum": 8 },
            "focus": { "type": "number", "exclusiveMinimum": 0, "maximum": 8 }
          }
        },
        "shadows": {
          "type": "object",
          "required": ["cardBlur", "cardOffsetY", "boardBlur", "buttonBlur"],
          "additionalProperties": false,
          "properties": {
            "cardBlur": { "type": "number", "minimum": 0, "maximum": 24 },
            "cardOffsetY": { "type": "number", "minimum": 0, "maximum": 12 },
            "boardBlur": { "type": "number", "minimum": 0, "maximum": 24 },
            "buttonBlur": { "type": "number", "minimum": 0, "maximum": 24 }
          }
        },
        "motion": {
          "type": "object",
          "required": ["titleRevealSeconds", "feedbackSeconds", "batchStepSeconds", "invalidReboundSeconds", "targetPulseHz"],
          "additionalProperties": false,
          "properties": {
            "titleRevealSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 2 },
            "feedbackSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 2 },
            "batchStepSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 0.5 },
            "invalidReboundSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "targetPulseHz": { "type": "number", "exclusiveMinimum": 0, "maximum": 10 }
          }
        },
        "dragonSkill": {
          "type": "object",
          "required": ["birthSeconds", "startScale", "arcLift", "originGlowRadius", "trailWidth"],
          "additionalProperties": false,
          "properties": {
            "birthSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "startScale": { "type": "number", "minimum": 0.01, "maximum": 0.5 },
            "arcLift": { "type": "number", "minimum": 0, "maximum": 80 },
            "originGlowRadius": { "type": "number", "minimum": 4, "maximum": 48 },
            "trailWidth": { "type": "number", "exclusiveMinimum": 0, "maximum": 12 }
          }
        },
        "route": {
          "type": "object",
          "required": ["lineWidth", "underlayWidth", "dash", "primaryAlpha", "secondaryAlpha", "markerRadius", "arrowSize", "arrowAlpha"],
          "additionalProperties": false,
          "properties": {
            "lineWidth": { "type": "number", "exclusiveMinimum": 0, "maximum": 8 },
            "underlayWidth": { "type": "number", "exclusiveMinimum": 0, "maximum": 12 },
            "dash": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number", "exclusiveMinimum": 0, "maximum": 24 }
            },
            "primaryAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
            "secondaryAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
            "markerRadius": { "type": "number", "minimum": 8, "maximum": 16 },
            "arrowSize": { "type": "number", "minimum": 4, "maximum": 12 },
            "arrowAlpha": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "title": {
          "type": "object",
          "required": ["mascotWidth", "mascotMaxWidth", "revealOffsetY", "revealAlphaStart", "peripheralAlpha"],
          "additionalProperties": false,
          "properties": {
            "mascotWidth": { "type": "number", "minimum": 80, "maximum": 180 },
            "mascotMaxWidth": { "type": "number", "minimum": 80, "maximum": 180 },
            "revealOffsetY": { "type": "number", "minimum": 0, "maximum": 24 },
            "revealAlphaStart": { "type": "number", "minimum": 0, "maximum": 1 },
            "peripheralAlpha": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  }
}
