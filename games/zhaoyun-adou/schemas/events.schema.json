{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhaoyun-adou.local/schemas/events.schema.json",
  "title": "Events manifest",
  "type": "object",
  "required": ["schemaVersion", "version", "gameVersion", "rulesetVersion", "contentVersion", "requiredCommonFields", "events"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "$ref": "#/$defs/version" },
    "version": { "$ref": "#/$defs/version" },
    "gameVersion": { "$ref": "#/$defs/version" },
    "rulesetVersion": { "$ref": "#/$defs/version" },
    "contentVersion": { "$ref": "#/$defs/version" },
    "requiredCommonFields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/field" }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "field": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "event": {
      "type": "object",
      "required": ["id", "category", "requiredFields", "privacy"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "category": { "$ref": "#/$defs/id" },
        "requiredFields": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/field" } },
        "privacy": { "enum": ["none", "pseudonymous", "personal"] }
      }
    }
  }
}
