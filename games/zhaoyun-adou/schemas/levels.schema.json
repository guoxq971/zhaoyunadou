{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhaoyun-adou.local/schemas/levels.schema.json",
  "title": "Levels manifest",
  "type": "object",
  "required": ["schemaVersion", "version", "maps", "stages"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "$ref": "#/$defs/version" },
    "version": { "$ref": "#/$defs/version" },
    "maps": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": { "^[a-z][a-z0-9.-]*$": { "$ref": "#/$defs/map" } },
      "additionalProperties": false
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "cell": {
      "type": "object",
      "required": ["r", "c"],
      "additionalProperties": false,
      "properties": {
        "r": { "type": "integer", "minimum": 0 },
        "c": { "type": "integer", "minimum": 0 }
      }
    },
    "cellList": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/cell" }
    },
    "map": {
      "type": "object",
      "required": ["lanes", "openCells", "spawnCells", "gateCells", "legacyPathLane"],
      "additionalProperties": false,
      "properties": {
        "symmetry": { "enum": ["none", "rotate-180"] },
        "lanes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/cellList" } },
        "openCells": { "$ref": "#/$defs/cellList" },
        "spawnCells": { "$ref": "#/$defs/cellList" },
        "gateCells": { "$ref": "#/$defs/cellList" },
        "spawnDecorationId": { "$ref": "#/$defs/id" },
        "legacyPathLane": { "type": "integer", "minimum": 0 }
      }
    },
    "stage": {
      "type": "object",
      "required": ["id", "name", "star", "mapId", "featuredHero", "waveCount", "enemyHpMul", "finalEnemy", "enemyPlan"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "star": { "type": "integer", "minimum": 1 },
        "mapId": { "$ref": "#/$defs/id" },
        "featuredHero": { "$ref": "#/$defs/id" },
        "waveCount": { "type": "integer", "minimum": 1 },
        "enemyHpMul": { "type": "number", "exclusiveMinimum": 0 },
        "finalEnemy": { "$ref": "#/$defs/id" },
        "enemyPlan": {
          "type": "object",
          "required": ["fastFromWave", "tankFromWave"],
          "additionalProperties": false,
          "properties": {
            "fastFromWave": { "type": "integer", "minimum": 1 },
            "tankFromWave": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
